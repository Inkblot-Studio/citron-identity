# Stage build config (stage.identity.citronos.com) — loaded by vite build.
# Host-aware fallbacks in src/lib/deploy-tier.ts map identity.citronos.com → prod API.
VITE_AUTH_API_URL=https://stage.api.identity.citronos.com
VITE_USE_MOCK_AUTH=false
VITE_ALLOWED_REDIRECT_ORIGINS=https://stage.console.citronos.com,https://console.citronos.com
