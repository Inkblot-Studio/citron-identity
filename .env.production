# Production build config (identity.citronos.com) — loaded by vite build.
# Values here are public (baked into the bundle); real secrets never go in this file.
VITE_AUTH_API_URL=https://api.identity.citronos.com
# Real backend, not the in-memory mocks (required since the VITE_USE_MOCK_AUTH gate).
VITE_USE_MOCK_AUTH=false
# Non-localhost origins the portal may redirect back to after login (SSO).
VITE_ALLOWED_REDIRECT_ORIGINS=https://console.citronos.com
