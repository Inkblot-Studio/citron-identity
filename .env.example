# Auth API (when using real backend)
# VITE_AUTH_API_URL=https://api.example.com
# VITE_USE_MOCK_AUTH=false

# Allowed redirect origins for cross-domain auth flow.
# Comma-separated. localhost is always allowed.
# Example: https://app-a.example.com,https://app-c.example.com
# VITE_ALLOWED_REDIRECT_ORIGINS=
